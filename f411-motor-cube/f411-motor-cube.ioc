# ---------- RCC / clocks ----------
# HSE 8 MHz crystal, PLL to 96 MHz SYSCLK
# APB1 = 48 MHz (USART2, TIM2/TIM4 timer clock = 96 MHz)
# APB2 = 96 MHz (TIM1 timer clock = 96 MHz)
RCC.AHBCLKDivider=RCC_SYSCLK_DIV1
RCC.APB1CLKDivider=RCC_HCLK_DIV2
RCC.APB1TimFreq_Value=96000000
RCC.APB2CLKDivider=RCC_HCLK_DIV1
RCC.APB2TimFreq_Value=96000000
RCC.CortexFreq_Value=96000000
RCC.FCLKCortexFreq_Value=96000000
RCC.FamilyName=M
RCC.HCLKFreq_Value=96000000
RCC.HPRE=RCC_SYSCLK_DIV1
RCC.I2SClocksFreq_Value=96000000
RCC.IPParameters=AHBCLKDivider,APB1CLKDivider,APB1TimFreq_Value,APB2CLKDivider,APB2TimFreq_Value,CortexFreq_Value,FCLKCortexFreq_Value,FamilyName,HCLKFreq_Value,HPRE,I2SClocksFreq_Value,LSE_Drive,LSE_VALUE,MCO2PinFreq_Value,MCOPinFreq_Value,PLL48CLKFreq_Value,PLLCLKFreq_Value,PLLM,PLLN,PLLP,PLLQ,PLLVCOMaxFreq,PLLVCOInputFreq,PLLVCOOutputFreq,PWRFreq_Value,RCC_48MHZ_HSI48,RTCCLKSelection,RTCFreq_Value,SYSCLKFreq_VALUE,SYSCLKSource,TimSysFreq_Value
RCC.LSE_Drive=RCC_LSEDRIVE_LOW
RCC.LSE_VALUE=32768
RCC.MCO2PinFreq_Value=96000000
RCC.MCOPinFreq_Value=96000000
RCC.PLL48CLKFreq_Value=96000000
RCC.PLLCLKFreq_Value=96000000
RCC.PLLM=8
RCC.PLLN=192
RCC.PLLP=RCC_PLLP_DIV2
RCC.PLLQ=4
RCC.PLLVCOMaxFreq=336000000
RCC.PLLVCOInputFreq=8000000
RCC.PLLVCOOutputFreq=192000000
RCC.PWRFreq_Value=96000000
RCC.RCC_48MHZ_HSI48=48000000
RCC.RTCCLKSelection=RCC_RTCCLKSOURCE_LSE
RCC.RTCFreq_Value=32768
RCC.SYSCLKFreq_VALUE=96000000
RCC.SYSCLKSource=RCC_SYSCLKSOURCE_PLLCLK
RCC.TimSysFreq_Value=96000000

# ---------- USART2 (command UART) ----------
USART2.BaudRate=115200
USART2.IPParameters=VirtualMode-Asynchronous,BaudRate,Mode,Parity,WordLength,StopBits
USART2.Mode=MODE_TX|RX
USART2.Parity=PARITY_NONE
USART2.StopBits=STOPBITS_1
USART2.VirtualMode-Asynchronous=VM_ASYNC
USART2.WordLength=WORDLENGTH_8B

# ---------- TIM1 — advanced-control motor PWM ----------
# 96 MHz clock, edge-aligned upcounting, ARR=4799 -> 20.0 kHz PWM.
#   f_pwm = TIM_CLK / (ARR + 1) = 96 MHz / 4800 = 20 kHz
# Dead-time DTG=63 (~0.66 us @ 96 MHz, NOT bench-verified).
# Break input DISABLED in Core/Src/tim.c — no BKIN pin is wired on
#   the board, so an enabled break with a floating BKIN line could
#   keep MOE off.  BreakPolarity/BreakFilter below are placeholders
#   only; do not re-enable break without configuring a physical BKIN
#   pin tied to a safe inactive level (see docs/KNOWN_RISKS.md).
TIM1.AutoReloadPreload=TIM_AUTORELOAD_PRELOAD_ENABLE
TIM1.Break2Filter=TIM_BREAK2FILTER_FDIV1
TIM1.Break2Polarity=TIM_BREAK2POLARITY_HIGH
TIM1.BreakFilter=TIM_BREAKFILTER_FDIV1
TIM1.BreakPolarity=TIM_BREAKPOLARITY_HIGH
TIM1.Channel-PWM\ Generation1\ CH1=ENABLE
TIM1.Channel-PWM\ Generation1\ CH1N=ENABLE
TIM1.Channel-PWM\ Generation1\ CH2=ENABLE
TIM1.Channel-PWM\ Generation1\ CH2N=ENABLE
TIM1.Channel-PWM\ Generation1\ CH3=ENABLE
TIM1.Channel-PWM\ Generation1\ CH3N=ENABLE
TIM1.CounterMode=TIM_COUNTERMODE_UP
TIM1.DeadTime=63
TIM1.IPParameters=Channel-PWM Generation1 CH1,Channel-PWM Generation1 CH1N,Channel-PWM Generation1 CH2,Channel-PWM Generation1 CH2N,Channel-PWM Generation1 CH3,Channel-PWM Generation1 CH3N,AutoReloadPreload,Break2Filter,Break2Polarity,BreakFilter,BreakPolarity,CounterMode,DeadTime,OffStateIDLE,OffStateRun,OutputCompare-PWM Generation1 No Output1,OutputCompare-PWM Generation1 No Output1N,OutputCompare-PWM Generation1 No Output2,OutputCompare-PWM Generation1 No Output2N,OutputCompare-PWM Generation1 No Output3,OutputCompare-PWM Generation1 No Output3N,Period,Prescaler,Pulse,RepetitionCounter,TIM_MasterSlaveMode,TIM_OCMode_PWM1
TIM1.OffStateIDLE=DISABLE
TIM1.OffStateRun=DISABLE
TIM1.OutputCompare-PWM\ Generation1\ No\ Output1=PWM
TIM1.OutputCompare-PWM\ Generation1\ No\ Output1N=PWM
TIM1.OutputCompare-PWM\ Generation1\ No\ Output2=PWM
TIM1.OutputCompare-PWM\ Generation1\ No\ Output2N=PWM
TIM1.OutputCompare-PWM\ Generation1\ No\ Output3=PWM
TIM1.OutputCompare-PWM\ Generation1\ No\ Output3N=PWM
TIM1.Period=4799
TIM1.Prescaler=0
TIM1.Pulse=0
TIM1.RepetitionCounter=0
TIM1.TIM_MasterSlaveMode=TIM_MASTERSLAVEMODE_DISABLE
TIM1.TIM_OCMode_PWM1=TIM_OCMODE_PWM1

# ---------- TIM2 — 32-bit 1 MHz microsecond timestamp ----------
# Free-running, no pins.  APB1 timer clock = 96 MHz, prescaler 95 -> 1 MHz.
# Used by hall_sensor.c for Hall edge timestamps / RPM period.
TIM2.IPParameters=Prescaler,Period
TIM2.Prescaler=95
TIM2.Period=4294967295

# ---------- TIM4 — Hall sensor interface (placeholder) ----------
# Kept for .ioc consistency. Runtime uses EXTI on PB6/PB7/PB8 + TIM2
# timestamps (see hall_sensor.c). TIM4 is initialised but not used
# for RPM measurement.
# 96 MHz / Prescaler 95 = 1 MHz timer clock
TIM4.IPParameters=Prescaler,TIM_MasterSlaveMode,TIM4_CounterMode
TIM4.Prescaler=95
TIM4.TIM4_CounterMode=TIM_COUNTERMODE_UP
TIM4.TIM_MasterSlaveMode=TIM_MASTERSLAVEMODE_DISABLE

# ---------- NVIC priorities ----------
# Note: TIM6_DAC_IRQn removed — STM32F411 has no TIM6/TIM7.
# Scheduler tick is SysTick (HAL_IncTick), not TIM6.
NVIC.BusFault_IRQn=true\:0\:0\:false\:false\:true\:false\:false
NVIC.DebugMonitor_IRQn=true\:0\:0\:false\:false\:true\:false\:false
NVIC.DMA1_Stream5_IRQn=true\:5\:0\:false\:false\:true\:true\:true
NVIC.DMA1_Stream6_IRQn=true\:5\:0\:false\:false\:true\:true\:true
NVIC.EXTI9_5_IRQn=true\:6\:0\:false\:false\:true\:true\:true
NVIC.HardFault_IRQn=true\:0\:0\:false\:false\:true\:false\:false
NVIC.MemoryManagement_IRQn=true\:0\:0\:false\:false\:true\:false\:false
NVIC.NonMaskableInt_IRQn=true\:0\:0\:false\:false\:true\:false\:false
NVIC.PendSV_IRQn=true\:0\:0\:false\:false\:true\:false\:false
NVIC.PriorityGroup=NVIC_PRIORITYGROUP_4
NVIC.SVCall_IRQn=true\:0\:0\:false\:false\:true\:false\:false
NVIC.SysTick_IRQn=true\:0\:0\:false\:false\:true\:false\:false
NVIC.TIM1_BRK_TIM9_IRQn=true\:5\:0\:false\:false\:true\:true\:true
NVIC.TIM1_UP_TIM10_IRQn=true\:5\:0\:false\:false\:true\:true\:true
NVIC.USART2_IRQn=true\:5\:0\:false\:false\:true\:true\:true
NVIC.UsageFault_IRQn=true\:0\:0\:false\:false\:true\:false\:false

